# StoryWeaver Environment Variables
# Copy this file to .env and fill in your actual values
# Do not commit .env to version control - it contains sensitive information

# ─── Application Settings ───────────────────────────────────────
NODE_ENV=development
VITE_APP_ID=your-app-id-here

# ─── Database ────────────────────────────────────────────────────
# MySQL connection string for Drizzle ORM
DATABASE_URL=mysql://user:password@localhost:3306/storyweaver

# ─── Authentication & Security ──────────────────────────────────
# JWT secret for session cookies (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-here

# OAuth configuration (if using OAuth2)
OAUTH_SERVER_URL=https://oauth.example.com
OWNER_OPEN_ID=your-owner-openid

# ─── AI Services ─────────────────────────────────────────────────
# Anthropic Claude API key for story generation
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-v0-...

# ElevenLabs API key for voice narration
# Get from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Suno API key for background music generation
# Get from: https://www.suno.ai/
SUNO_API_KEY=your-suno-api-key

# ─── Print-on-Demand (Printful) ─────────────────────────────────
# Printful API key for print ordering
# Get from: https://www.printful.com/oauth
# IMPORTANT: This is optional. The app will run without it (print features disabled)
PRINTFUL_API_KEY=your-printful-api-key

# ─── Payments (Stripe) ──────────────────────────────────────────
# Stripe API keys for subscription management
# Get from: https://dashboard.stripe.com/apikeys
# IMPORTANT: These are optional. The app will run without them (payment features disabled)

# Secret key (NEVER share this publicly)
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret (for processing Stripe events)
STRIPE_WEBHOOK_SECRET=whsec_...

# Product price IDs (create in Stripe Dashboard)
STRIPE_PRICE_MONTHLY=price_1A2B3C...
STRIPE_PRICE_ANNUAL=price_2C3D4E...
STRIPE_PRICE_FAMILY=price_3D4E5F...

# ─── Internal Services ──────────────────────────────────────────
# Built-in Forge API (if using custom story engine)
BUILT_IN_FORGE_API_URL=http://localhost:3001
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ─── Caching (Optional) ──────────────────────────────────────────
# Redis URL for distributed caching (optional, falls back to in-memory)
# Format: redis://[:password]@host:port
REDIS_URL=

# ─── Notes ──────────────────────────────────────────────────────
# Optional Services:
# - PRINTFUL_API_KEY: Leave blank to disable print-on-demand features
# - STRIPE_SECRET_KEY/STRIPE_WEBHOOK_SECRET: Leave blank to disable payment features
# - REDIS_URL: Leave blank to use in-memory caching
#
# Required Services:
# - ANTHROPIC_API_KEY: Required for AI story generation
# - ELEVENLABS_API_KEY: Required for voice narration
# - DATABASE_URL: Required for application data
#
# The application will start successfully even with optional services disabled,
# but those features will return "not configured" errors to users.
